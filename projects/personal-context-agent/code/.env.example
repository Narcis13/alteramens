# Copy to `.env` and fill in real values. `.env` is gitignored.
# Provision steps: see ../plan-turso-sync.md §Phase 0.

# Remote libsql URL from `turso db show pca-prod --url`
TURSO_DB_URL=<your-libsql-url>

# Token from `turso db tokens create pca-prod --expiration none`
TURSO_AUTH_TOKEN=<your-turso-auth-token>

# Path for the local embedded replica file (absolute path recommended)
PCA_LOCAL_REPLICA=<your-local-replica-path>

# How often (seconds) libsql client pulls/pushes changes. Default 60.
PCA_SYNC_INTERVAL_SEC=60
